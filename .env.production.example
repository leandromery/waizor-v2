# ============================================================
# waizor-v2 — production env (VPS)
#
# Copy this file to `.env` on the server and fill in real values:
#     cp .env.production.example .env
# docker-compose auto-loads `.env` for BOTH build-arg interpolation
# (NEXT_PUBLIC_*) and container runtime (env_file). Never commit `.env`.
# ============================================================

# ---- Build-time (baked into the client bundle) -------------
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://vgyepacjxciicqylurxd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical public URL of this deployment
NEXT_PUBLIC_SITE_URL=https://v2.waizor.com.br

# UI locale (pt or en)
NEXT_PUBLIC_APP_LOCALE=pt

# ---- Runtime (server-only secrets) -------------------------
# Supabase service-role key — bypasses RLS, server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp token encryption (64 hex chars = 32 bytes, AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: reuse the SAME value already in use if WhatsApp tokens are
# already stored — rotating it orphans every encrypted token.
ENCRYPTION_KEY=your-64-char-hex-key

# Meta app credentials (Meta for Developers → App Settings → Basic)
META_APP_SECRET=your-meta-app-secret
META_APP_ID=your-meta-app-id

# ---- Recommended -------------------------------------------
# Shared secret for GET /api/automations/cron and /api/flows/cron.
# Generate: openssl rand -hex 32
AUTOMATION_CRON_SECRET=generate-a-long-random-string

# Hardening: pin invite-link hostnames to this deployment.
ALLOWED_INVITE_HOSTS=v2.waizor.com.br
